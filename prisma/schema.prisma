generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String  @id
  email               String? @unique
  name                String?
  given_name          String?
  family_name         String?
  slack_id            String?
  verification_status String?
  raw                 Json?
  oauth_token         String?
  firstSeen           DateTime @default(now())
  lastSeen            DateTime @updatedAt
}
